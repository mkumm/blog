---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FallbackImage from '../assets/hero-backup.png';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

import '../styles/global.css'

type Props = CollectionEntry<'blog'>['data'] & { readingTime?: number };

const { title, description, pubDate, updatedDate, heroImage, readingTime } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage ?? FallbackImage} ogType="article" pubDate={pubDate} updatedDate={updatedDate} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"image": new URL((heroImage ?? FallbackImage).src, Astro.site).href,
			"datePublished": pubDate.toISOString(),
			"dateModified": (updatedDate ?? pubDate).toISOString(),
			"author": {
				"@type": "Person",
				"name": "Michael Kumm",
				"url": "https://mkumm.com"
			},
			"publisher": {
				"@type": "Organization",
				"name": "Michael Kumm",
				"url": "https://mkumm.com"
			},
			"url": Astro.url.href,
			"mainEntityOfPage": Astro.url.href
		})}></script>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.hero-image img {
				display: block;
				width: 100%;
				max-height: 460px;
				object-fit: cover;
				border-radius: 0;
			}
			@media (max-width: 720px) {
				.hero-image img { max-height: 240px; }
			}
			.prose {
				width: 700px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 0 4rem;
				color: rgb(var(--gray-dark));
			}
			.post-header {
				margin-bottom: 2.5rem;
				text-align: center;
			}
			.post-header .date {
				display: block;
				margin-bottom: 0.75rem;
			}
			.post-header h1 {
				margin: 0 0 1.5rem 0;
				font-size: 2.5rem;
				line-height: 1.15;
			}
			.post-header hr {
				margin: 0;
				border-top-color: rgb(var(--gray-light));
			}
			.prose :global(.mermaid) {
				overflow-x: auto;
			}
			.prose :global(.mermaid svg) {
				max-width: none;
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.825rem;
				margin-top: 0.4em;
				color: rgb(var(--gray));
			}
			.post-meta {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.75rem;
				margin-bottom: 0.75rem;
				color: rgb(var(--gray));
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.07em;
				font-weight: 500;
			}
			.post-meta .sep { opacity: 0.4; }
			@media (max-width: 720px) {
				.prose {
					padding: 1.5rem 1rem 3rem;
					max-width: 100%;
				}
				.post-header h1 { font-size: 1.75rem; }
			}
		</style>
	</head>

	<body>
		<Header />
		{heroImage && (
			<div class="hero-image">
				<Image layout="constrained" src={heroImage} alt={title} loading="eager" />
			</div>
		)}
		<main>
			<article>
				<div class="prose">
					<div class="post-header">
						<div class="post-meta">
							<FormattedDate date={pubDate} />
							{readingTime && <><span class="sep">·</span><span>{readingTime} min read</span></>}
							{updatedDate && <><span class="sep">·</span><span style="font-style:italic">Updated <FormattedDate date={updatedDate} /></span></>}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			import mermaid from 'mermaid';
			const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			mermaid.initialize({ startOnLoad: false, theme: isDark ? 'dark' : 'default' });
			mermaid.run();
		</script>
	</body>
</html>
