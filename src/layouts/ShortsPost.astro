---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FallbackImage from '../assets/hero-backup.png';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

import '../styles/global.css'

interface Props extends CollectionEntry<'shorts'>['data'] {
	prevPost?: CollectionEntry<'shorts'> | null;
	nextPost?: CollectionEntry<'shorts'> | null;
	readingTime?: number;
}

const { title, description, pubDate, updatedDate, heroImage, prevPost, nextPost, readingTime } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage ?? FallbackImage} ogType="article" pubDate={pubDate} updatedDate={updatedDate} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"image": new URL((heroImage ?? FallbackImage).src, Astro.site).href,
			"datePublished": pubDate.toISOString(),
			"dateModified": (updatedDate ?? pubDate).toISOString(),
			"author": {
				"@type": "Person",
				"name": "Michael Kumm",
				"url": "https://mkumm.com"
			},
			"publisher": {
				"@type": "Organization",
				"name": "Michael Kumm",
				"url": "https://mkumm.com"
			},
			"url": Astro.url.href,
			"mainEntityOfPage": Astro.url.href
		})}></script>
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.hero-image img {
				display: block;
				width: 100%;
				max-height: 460px;
				object-fit: cover;
				border-radius: 0;
			}
			@media (max-width: 720px) {
				.hero-image img { max-height: 240px; }
			}
			.prose {
				width: 700px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 0 4rem;
				color: rgb(var(--gray-dark));
			}
			.post-header {
				margin-bottom: 2.5rem;
				text-align: center;
			}
			.post-header .date {
				display: block;
				margin-bottom: 0.75rem;
			}
			.post-header h1 {
				margin: 0 0 1.5rem 0;
				font-size: 2.5rem;
				line-height: 1.15;
			}
			.post-header hr {
				margin: 0;
				border-top-color: rgb(var(--gray-light));
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.825rem;
				margin-top: 0.4em;
				color: rgb(var(--gray));
			}
			.post-meta {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.75rem;
				margin-bottom: 0.75rem;
				color: rgb(var(--gray));
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.07em;
				font-weight: 500;
			}
			.post-meta .sep { opacity: 0.4; }

			/* ── Prev / Next navigation ── */
			.post-navigation {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
				margin-top: 3.5rem;
				padding-top: 2rem;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.nav-link {
				display: flex;
				flex-direction: column;
				gap: 0.35rem;
				padding: 1rem 1.1rem;
				border-radius: 8px;
				background: var(--bg-secondary);
				border: 1px solid rgba(var(--gray-light), 0.8);
				text-decoration: none;
				transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
			}
			.nav-link:hover {
				box-shadow: var(--box-shadow);
				transform: translateY(-2px);
				border-color: rgba(var(--accent-rgb), 0.3);
				text-decoration: none;
			}
			.nav-link.next { text-align: right; }
			.nav-label {
				font-size: 0.75rem;
				color: var(--accent);
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.07em;
			}
			.nav-title {
				color: rgb(var(--black));
				font-weight: 600;
				font-size: 0.95rem;
				font-family: 'Lora', Georgia, serif;
				line-height: 1.3;
			}
			@media (max-width: 720px) {
				.prose {
					padding: 1.5rem 1rem 3rem;
					max-width: 100%;
				}
				.post-header h1 { font-size: 1.75rem; }
				.post-navigation {
					grid-template-columns: 1fr;
					gap: 0.75rem;
					margin-top: 2.5rem;
				}
				.nav-link.next { text-align: left; }
			}
		</style>
	</head>

	<body>
		<Header />
		{heroImage && (
			<div class="hero-image">
				<Image layout="constrained" src={heroImage} alt={title} loading="eager" />
			</div>
		)}
		<main>
			<article>
				<div class="prose">
					<div class="post-header">
						<div class="post-meta">
							<FormattedDate date={pubDate} />
							{readingTime && <><span class="sep">·</span><span>{readingTime} min read</span></>}
							{updatedDate && <><span class="sep">·</span><span style="font-style:italic">Updated <FormattedDate date={updatedDate} /></span></>}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />

					<nav class="post-navigation">
						{prevPost ? (
							<a href={`/shorts/${prevPost.id}/`} class="nav-link prev">
								<span class="nav-label">← Previous</span>
								<span class="nav-title">{prevPost.data.title}</span>
							</a>
						) : <div />}
						{nextPost && (
							<a href={`/shorts/${nextPost.id}/`} class="nav-link next">
								<span class="nav-label">Next →</span>
								<span class="nav-title">{nextPost.data.title}</span>
							</a>
						)}
					</nav>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
