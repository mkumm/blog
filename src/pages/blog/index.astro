---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((post) => ({
		...post,
		readingTime: Math.max(1, Math.ceil((post.body?.trim().split(/\s+/).length ?? 0) / 200)),
	}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1020px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
			.page-header {
				margin-bottom: 2.5rem;
				padding-bottom: 1.25rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.page-header h1 {
				margin: 0 0 0.25rem 0;
				font-size: 2rem;
			}
			.page-header p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 2rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			@keyframes fadeInUp {
				from { opacity: 0; transform: translateY(16px); }
				to   { opacity: 1; transform: translateY(0); }
			}
			ul li {
				animation: fadeInUp 0.35s ease both;
			}
			ul li:nth-child(1)  { animation-delay: 0.04s; }
			ul li:nth-child(2)  { animation-delay: 0.08s; }
			ul li:nth-child(3)  { animation-delay: 0.12s; }
			ul li:nth-child(4)  { animation-delay: 0.16s; }
			ul li:nth-child(5)  { animation-delay: 0.20s; }
			ul li:nth-child(6)  { animation-delay: 0.24s; }
			ul li:nth-child(7)  { animation-delay: 0.28s; }
			ul li:nth-child(8)  { animation-delay: 0.32s; }
			ul li:nth-child(9)  { animation-delay: 0.36s; }
			ul li:nth-child(10) { animation-delay: 0.40s; }

			ul li a {
				display: block;
				text-decoration: none;
				color: inherit;
				border-radius: 10px;
				overflow: hidden;
				background: var(--bg-secondary);
				border: 1px solid rgba(var(--gray-light), 0.8);
				transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
			}
			ul li a:hover {
				box-shadow: var(--box-shadow);
				transform: translateY(-3px);
				border-color: rgba(var(--accent-rgb), 0.3);
				text-decoration: none;
			}
			ul li img {
				display: block;
				width: 100% !important;
				height: 220px;
				max-width: 100% !important;
				margin: 0 !important;
				object-fit: cover;
				border-radius: 0;
			}
			.card-body {
				padding: 1.25rem 1.25rem 1.1rem;
			}
			.card-date {
				font-size: 0.78rem;
				text-transform: uppercase;
				letter-spacing: 0.07em;
				font-weight: 500;
				color: rgb(var(--gray));
				margin-bottom: 0.4rem;
			}
			.card-title {
				font-family: 'Lora', Georgia, serif;
				font-size: 1.15rem;
				font-weight: 600;
				color: rgb(var(--black));
				line-height: 1.35;
				margin: 0;
				transition: color 0.15s ease;
			}
			ul li a:hover .card-title {
				color: var(--accent);
			}
			.card-description {
				font-size: 0.875rem;
				color: rgb(var(--gray));
				line-height: 1.5;
				margin: 0.5rem 0 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.card-read-time {
				font-size: 0.75rem;
				color: rgb(var(--gray));
				margin-top: 0.6rem;
			}
			@media (max-width: 720px) {
				main { width: 100%; max-width: 100%; }
				ul {
					grid-template-columns: 1fr;
					gap: 1.25rem;
				}
				ul li img { height: 200px; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Blog</h1>
				<p>Writing on software, systems, and things I find interesting.</p>
			</div>
			<ul>
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							{post.data.heroImage && (
								<Image
									width={720}
									height={360}
									src={post.data.heroImage}
									alt={"image: " + post.data.title}
									loading="eager"
								/>
							)}
							<div class="card-body">
								<p class="card-date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h4 class="card-title">{post.data.title}</h4>
								{post.data.description && (
									<p class="card-description">{post.data.description}</p>
								)}
								<p class="card-read-time">{post.readingTime} min read</p>
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
