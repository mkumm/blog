---
import { Image } from 'astro:assets';
import IndexHeroImage from '../../assets/shorts/hero-shorts.png';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('shorts')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1060px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
			.hero-image img {
				display: block;
				width: 100%;
				max-height: 360px;
				object-fit: cover;
				border-radius: 0;
			}
			.page-header {
				margin-bottom: 2.5rem;
				padding-bottom: 1.25rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.page-header h1 {
				margin: 0 0 0.25rem 0;
				font-size: 2rem;
			}
			.page-header p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.25rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			@keyframes fadeInUp {
				from { opacity: 0; transform: translateY(12px); }
				to   { opacity: 1; transform: translateY(0); }
			}
			ul li {
				border-radius: 10px;
				border: 1px solid rgba(var(--gray-light), 0.8);
				background: var(--bg-secondary);
				transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
				animation: fadeInUp 0.35s ease both;
				overflow: hidden;
			}
			ul li:nth-child(1)  { animation-delay: 0.04s; }
			ul li:nth-child(2)  { animation-delay: 0.08s; }
			ul li:nth-child(3)  { animation-delay: 0.12s; }
			ul li:nth-child(4)  { animation-delay: 0.16s; }
			ul li:nth-child(5)  { animation-delay: 0.20s; }
			ul li:nth-child(6)  { animation-delay: 0.24s; }
			ul li:nth-child(7)  { animation-delay: 0.28s; }
			ul li:nth-child(8)  { animation-delay: 0.32s; }
			ul li:nth-child(9)  { animation-delay: 0.36s; }
			ul li:nth-child(10) { animation-delay: 0.40s; }
			ul li:nth-child(11) { animation-delay: 0.44s; }
			ul li:nth-child(12) { animation-delay: 0.48s; }
			ul li:hover {
				box-shadow: var(--box-shadow);
				transform: translateY(-2px);
				border-color: rgba(var(--accent-rgb), 0.3);
			}
			ul li a {
				display: flex;
				flex-direction: column;
				text-decoration: none;
				color: inherit;
				height: 100%;
			}
			ul li img {
				display: block;
				width: 100% !important;
				height: 160px;
				max-width: 100% !important;
				margin: 0 !important;
				object-fit: cover;
				border-radius: 0;
			}
			.post-content {
				flex: 1;
				padding: 1rem 1.1rem 1.1rem;
				display: flex;
				flex-direction: column;
			}
			.card-date {
				font-size: 0.78rem;
				text-transform: uppercase;
				letter-spacing: 0.07em;
				font-weight: 500;
				color: rgb(var(--gray));
				margin-bottom: 0.3rem;
			}
			.card-title {
				font-family: 'Lora', Georgia, serif;
				font-size: 1.1rem;
				font-weight: 600;
				color: rgb(var(--black));
				line-height: 1.35;
				margin: 0 0 0.4rem 0;
				transition: color 0.15s ease;
			}
			.card-description {
				color: rgb(var(--gray));
				font-size: 0.9rem;
				line-height: 1.5;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			ul li:hover .card-title {
				color: var(--accent);
			}
			@media (max-width: 900px) {
				ul { grid-template-columns: repeat(2, 1fr); }
			}
			@media (max-width: 560px) {
				main { width: 100%; max-width: 100%; }
				ul { grid-template-columns: 1fr; gap: 0.75rem; }
				ul li img { height: 180px; }
				.card-title { font-size: 1rem; }
				.card-description { font-size: 0.85rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="hero-image">
			{IndexHeroImage && (
				<Image layout="constrained" src={IndexHeroImage} alt="Shorts hero" loading="eager" />
			)}
		</div>
		<main>
			<div class="page-header">
				<h1>Shorts</h1>
				<p>Brief thoughts, observations, and things worth sharing.</p>
			</div>
			<ul>
				{posts.map((post) => (
					<li>
						<a href={`/shorts/${post.id}/`}>
							{post.data.heroImage && (
								<Image
									width={400}
									height={240}
									src={post.data.heroImage}
									alt={"Image: " + post.data.title}
								/>
							)}
							<div class="post-content">
								<p class="card-date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h4 class="card-title">{post.data.title}</h4>
								{post.data.description && (
									<p class="card-description">{post.data.description}</p>
								)}
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
