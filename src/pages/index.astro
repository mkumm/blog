---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import IndexHeroImage from "../assets/pages/hero-index.png";
import { Image } from "astro:assets";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Michael Kumm",
			"alternateName": "mkumm",
			"url": "https://mkumm.com",
			"jobTitle": "Senior Software Engineer",
			"sameAs": [
				"https://twitter.com/mkumm",
				"https://linkedin.com/in/mkumm",
				"https://github.com/mkumm"
			]
		})}></script>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "Michael Kumm",
			"url": "https://mkumm.com",
			"description": SITE_DESCRIPTION,
			"author": {
				"@type": "Person",
				"name": "Michael Kumm"
			}
		})}></script>
		<style>
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				width: 100%;
				max-height: 440px;
				object-fit: cover;
				border-radius: 0;
				box-shadow: none;
			}
			@media (max-width: 720px) {
				.hero-image img {
					max-height: 220px;
				}
			}
			.intro {
				display: flex;
				align-items: flex-start;
				gap: 2rem;
				margin-bottom: 2rem;
			}
			.intro-photo {
				width: 100px;
				height: 100px;
				flex-shrink: 0;
				border-radius: 12px;
				object-fit: cover;
				object-position: center top;
				margin: 0 !important;
				width: 100px !important;
				max-width: 100px !important;
			}
			.intro-text {
				flex: 1;
				min-width: 0;
			}
			.intro-text h1 {
				font-size: 1.4rem;
				margin: 0 0 0.1rem 0;
			}
			.intro-tagline {
				font-size: 0.925rem;
				color: rgb(var(--gray));
				margin: 0;
				font-weight: 500;
				line-height: 1.4;
			}
			@media (max-width: 540px) {
				.intro {
					flex-direction: column;
					align-items: center;
					text-align: center;
					gap: 0.75rem;
				}
				.intro-photo {
					width: 80px !important;
					max-width: 80px !important;
					height: 80px;
				}
				.tech-tags {
					justify-content: center;
				}
			}
			.nav-links {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0.75rem;
				margin: 1.75rem 0;
			}
			.nav-link-card {
				display: block;
				padding: 0.875rem 1rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				text-decoration: none;
				color: inherit;
				transition: border-color 0.15s ease, background 0.15s ease;
			}
			.nav-link-card:hover {
				border-color: var(--accent);
				background: rgba(193, 116, 86, 0.04);
			}
			.nav-link-card .card-title {
				display: block;
				font-family: 'Lora', Georgia, serif;
				font-weight: 600;
				font-size: 1rem;
				color: rgb(var(--black));
				margin-bottom: 0.2rem;
			}
			.nav-link-card .card-desc {
				display: block;
				font-size: 0.8rem;
				color: rgb(var(--gray));
				line-height: 1.4;
			}
			@media (max-width: 540px) {
				.nav-links { grid-template-columns: 1fr; }
			}
.tech-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.3rem;
				margin: 0.5rem 0 0;
			}
			.tech-tag {
				font-size: 0.65rem;
				font-weight: 500;
				padding: 0.15rem 0.45rem;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray));
				letter-spacing: 0.03em;
				text-transform: uppercase;
			}
			.contact-callout {
				margin: 1.75rem 0;
				padding: 1rem 1.25rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				border-left: 3px solid var(--accent);
				font-size: 0.9rem;
				color: rgb(var(--gray-dark));
			}
			.contact-callout a {
				color: var(--accent);
				font-weight: 500;
			}
			.contact-callout a:hover {
				text-decoration: underline;
			}
			.page-footer-note {
				margin-top: 3rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgb(var(--gray-light));
				font-size: 0.875rem;
				color: rgb(var(--gray));
				text-align: center;
			}
			.page-footer-note a {
				color: rgb(var(--gray));
			}
			.page-footer-note a:hover {
				color: var(--accent);
			}
		</style>
	</head>

	<body>
		<Header />
		<div class="hero-image">
			{IndexHeroImage && (
				<Image src={IndexHeroImage} alt="hero image" loading="eager" />
			)}
		</div>
		<main>
			<div class="intro">
				<img src="/profiles/mkumm.png" alt="Michael Kumm" class="intro-photo" />
				<div class="intro-text">
					<h1>Michael Kumm</h1>
					<p class="intro-tagline">Senior Software Engineer <br />Krakow, PL & Detroit, MI</p>
					<div class="tech-tags">
						{["Elixir", "Phoenix", "LiveView", "AI Tooling", "Surface"].map(tag => (
							<span class="tech-tag">{tag}</span>
						))}
					</div>
				</div>
			</div>

			<p>
				I'm a senior software engineer who likes building systems that are elegant
				under pressure—recently that's meant <strong>LiveView</strong> interfaces,
				<strong>AI automation</strong> tooling, and diving deep into event streaming.
				Outside of work I build things for the fun of it—privacy-first, ad-free, as
				close to free as possible. <a href="https://sprytna.com"><strong>Sprytna.com</strong></a>
				is a hub for those projects.
			</p>
			<p>
				Away from the keyboard I split my time between <strong>Krakow and Michigan</strong>,
				walk a lot, take photos, and am slowly learning <strong>Polish</strong>.
				I have a soft spot for <strong>cask ales</strong> and a long-standing fascination
				with <strong>probability and games of chance</strong>.
			</p>

			<div class="nav-links">
				<a href="/blog/" class="nav-link-card">
					<span class="card-title">Blog</span>
					<span class="card-desc">Technical deep-dives and longer essays</span>
				</a>
				<a href="/shorts/" class="nav-link-card">
					<span class="card-title">Shorts</span>
					<span class="card-desc">Casual notes and personal observations</span>
				</a>
				<a href="/now/" class="nav-link-card">
					<span class="card-title">Now</span>
					<span class="card-desc">What I'm currently focused on</span>
				</a>
			</div>

			<div class="contact-callout">
				If any of this resonates—Elixir, event streaming, privacy-first tools, expat life in Krakow, cask ales—drop me a line at <a href="mailto:hello@mkumm.com">hello@mkumm.com</a>.
			</div>

<p class="page-footer-note">
				All photos on this site are my own, available under a Creative Commons license.
				DM me on <a href="https://x.com/mkumm">Twitter</a> or
				<a href="https://www.instagram.com/mkumm/">Instagram</a> for full-resolution versions.
			</p>
		</main>
	</body>
	<Footer />
</html>
