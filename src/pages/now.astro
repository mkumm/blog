---
import NowHeroImage from "../assets/pages/hero-now.png";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { SITE_TITLE } from "../consts";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import PersonLink from "../components/PersonLink.astro";
import { books, albums } from "../data/now";

const recentShorts = (await getCollection('shorts'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const readingBooks = books.filter(b => b.status === 'reading');
const finishedBooks = books.filter(b => b.status === 'finished');

function progressBar(pct: number): { filled: string; empty: string } {
	const total = 20;
	const n = Math.round(pct * total / 100);
	return { filled: '█'.repeat(n), empty: '░'.repeat(total - n) };
}

function starSegments(rating: number): Array<'full' | 'half' | 'empty'> {
	return Array.from({ length: 5 }, (_, i) => {
		const pos = i + 1;
		if (rating >= pos) return 'full';
		if (rating >= pos - 0.5) return 'half';
		return 'empty';
	});
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Now — ${SITE_TITLE}`}
			description="What I'm focused on right now — inspired by Derek Sivers' now page movement."
		/>
		<style>
			.hero-image img {
				display: block;
				width: 100%;
				max-height: 440px;
				object-fit: cover;
				border-radius: 0;
			}
			@media (max-width: 720px) {
				.hero-image img { max-height: 220px; }
			}
			main {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2.5rem 1.5rem;
			}
			.page-header {
				margin-bottom: 2.5rem;
				padding-bottom: 1.25rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.page-header h1 {
				margin: 0 0 0.25rem 0;
				font-size: 2rem;
			}
			.page-header p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			@media (max-width: 720px) {
				main { width: 100%; max-width: 100%; padding: 1.5rem 1rem; }
			}
			.shorts-list {
				list-style: none;
				padding: 0;
				margin: 0 0 1rem 0;
			}
			.shorts-list li {
				padding: 0.75rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.shorts-list li:first-child {
				border-top: 1px solid rgb(var(--gray-light));
			}
			.shorts-list a {
				display: flex;
				gap: 1rem;
				align-items: baseline;
				text-decoration: none;
				color: inherit;
			}
			.shorts-list a:hover .short-title {
				color: var(--accent);
			}
			.short-date {
				font-size: 0.78rem;
				text-transform: uppercase;
				letter-spacing: 0.07em;
				font-weight: 500;
				color: rgb(var(--gray));
				white-space: nowrap;
				flex-shrink: 0;
			}
			.short-title {
				font-family: 'Lora', Georgia, serif;
				font-weight: 600;
				color: rgb(var(--black));
				transition: color 0.15s ease;
			}
			.short-description {
				font-size: 0.9rem;
				color: rgb(var(--gray));
				margin: 0.2rem 0 0 0;
			}
.see-all {
				font-size: 0.95rem;
				font-weight: 500;
			}
			.item-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.item-list li {
				padding: 0.85rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.item-list li:first-child {
				border-top: 1px solid rgb(var(--gray-light));
			}
			.item-row {
				display: flex;
				gap: 0.85rem;
				align-items: flex-start;
			}
			.item-thumb {
				width: 72px;
				flex-shrink: 0;
				border-radius: 3px;
				object-fit: cover;
				display: block;
			}
			.item-thumb.book {
				height: 100px;
			}
			.item-thumb.music {
				height: 72px;
			}
			.item-content {
				flex: 1;
				min-width: 0;
			}
			.item-header {
				display: flex;
				align-items: center;
				gap: 0.65rem;
				margin-bottom: 0.3rem;
			}
			.item-title {
				font-family: 'Lora', Georgia, serif;
				font-weight: 600;
				color: rgb(var(--black));
				text-decoration: none;
			}
			.item-title:hover {
				color: var(--accent);
			}
			.progress-bar {
				display: flex;
				align-items: center;
				gap: 0.35rem;
				margin-top: 0.35rem;
				font-family: 'Courier New', Courier, monospace;
				font-size: 0.78rem;
				line-height: 1;
			}
			.progress-filled {
				color: var(--accent);
			}
			.progress-empty {
				color: rgb(var(--gray-light));
			}
			.progress-pct {
				color: rgb(var(--gray));
				font-size: 0.72rem;
			}
			.star-display {
				display: inline-flex;
				gap: 0.05rem;
				margin-top: 0.35rem;
				font-size: 1rem;
				line-height: 1;
			}
			.star {
				position: relative;
				display: inline-block;
				color: rgb(var(--gray-light));
			}
			.star.full {
				color: var(--accent);
			}
			.star.half::after {
				content: '★';
				position: absolute;
				left: 0;
				top: 0;
				clip-path: inset(0 50% 0 0);
				color: var(--accent);
			}
			.item-note {
				font-size: 0.9rem;
				color: rgb(var(--gray));
				margin: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="hero-image">
			<Image src={NowHeroImage} alt="Now page hero" loading="eager" />
		</div>
		<main>
			<div class="page-header">
				<h1>Now Page</h1>
				<p>A snapshot of what I'm focused on — last updated April 16, 2026.</p>
			</div>

			<p>
				This is a <a href="https://nownownow.com/about">now page</a>.
				<PersonLink
					img_src="/profiles/sivers.png"
					name="Derek Sivers"
					link="https://sive.rs/"
				/> has inspired
				<a href="https://nownownow.com/">a growing number of "nowers"</a>
				to create these. If you have your own site, you should consider adding a
				<b>Now page</b> too.
			</p>

			<h2>Poland</h2>
			<p>
				I am an American with residency in Poland, living in Krakow. I mostly work from our
				modest apartment but also have access to a co-working space near the city center.
				Krakow keeps surprising me — lately I've been catching live events and wandering into
				things I wouldn't have found anywhere else.
			</p>
			<p>I still maintain my home in Michigan and travel back often.</p>

			<h2>Nauka języka polskiego (Learning Polish)</h2>
			<p>
				I'm finally learning Polish. Progress is slow, but I'm really enjoying it. If you're also
				interested in learning Polish, I highly recommend
				<a href="https://e-polish.eu/polish-for-foreigners">Glossa</a> and they work with students
				worldwide. A special thank you to <PersonLink
					img_src="/profiles/magda.png"
					name="Magdalena Wyglądacz"
					link="https://e-polish.eu/en/polish_teachers_online/magdalena_wygladacz"
				/>, my ever patient (and professional) teacher!
			</p>



			<h2>Working at DraftKings</h2>
			<p>
				I write code (mostly Elixir, Phoenix, LiveView, Surface, and RabbitMQ) at <a href="https://www.draftkings.com/">DraftKings</a>,
				one of the largest online sportsbooks and casinos. Right now I'm also leaning into new
				opportunities to learn — C#, AI integration, and Kafka are all on my plate. Some of the
				most supportive and talented people I've worked with in my career.
			</p>

			<h2>Solo Projects</h2>
			<dl>
				<dt>Any One Will Do</dt>
				<dd>A randomizer built with the features I actually wanted: no ads, random group formation,
				and a cleaner experience. We just hit our 30-day launch milestone — still learning and
				iterating. <a href="https://anyonewilldo.com">anyonewilldo.com</a></dd>

				<dt>Sprytna Cards</dt>
				<dd>Six months in, with about half of all users still active. The focus has shifted to
				providing the platform behind NFC cards — and we now offer custom printing for users in
				reasonable shipping locations. <a href="https://sprytna.cards/">sprytna.cards</a></dd>

				<dt>Sprytna Maps</dt>
				<dd>A way to share your city with people who matter — build a personal map of your
				favorite spots and send it to friends visiting your town.
				<a href="https://sprytnamaps.com">sprytnamaps.com</a></dd>
			</dl>

			<h2>Personal Writing</h2>
			<p>
				My <a href="/shorts/">Shorts</a> are the more personal corner of this site — quick notes,
				observations, and things from daily life in Krakow, side projects, and whatever catches
				my attention. Think of it as a personal blog in compact form.
			</p>
			<ul class="shorts-list">
				{recentShorts.map((post) => (
					<li>
						<a href={`/shorts/${post.id}/`}>
							<span class="short-date"><FormattedDate date={post.data.pubDate} /></span>
							<span class="short-title">{post.data.title}</span>
						</a>
						{post.data.description && <p class="short-description">{post.data.description}</p>}
					</li>
				))}
			</ul>
			<a href="/shorts/" class="see-all">See all shorts →</a>

			<h2>Books and Music</h2>

			<h3>Currently Reading</h3>
			<ul class="item-list">
				{readingBooks.map(book => (
					<li>
						<div class="item-row">
							<img src={book.image} class="item-thumb book" alt={`${book.title} cover`} />
							<div class="item-content">
								<div class="item-header">
									<a href={book.url} class="item-title">{book.title}</a>
								</div>
								{book.note && <p class="item-note">{book.note}</p>}
								<div class="progress-bar">
									<span class="progress-filled">{progressBar(book.progress!).filled}</span><span class="progress-empty">{progressBar(book.progress!).empty}</span>
									<span class="progress-pct">{book.progress}%</span>
								</div>
							</div>
						</div>
					</li>
				))}
			</ul>

			<h3>Just Finished</h3>
			<ul class="item-list">
				{finishedBooks.map(book => (
					<li>
						<div class="item-row">
							<img src={book.image} class="item-thumb book" alt={`${book.title} cover`} />
							<div class="item-content">
								<div class="item-header">
									<a href={book.url} class="item-title">{book.title}</a>
								</div>
								<div class="star-display">
									{starSegments(book.rating!).map(s => (
										<span class={`star ${s}`}>{s === 'full' ? '★' : '☆'}</span>
									))}
								</div>
								{book.note && <p class="item-note">{book.note}</p>}
							</div>
						</div>
					</li>
				))}
			</ul>

			<h3>Currently Listening</h3>
			<ul class="item-list">
				{albums.map(album => (
					<li>
						<div class="item-row">
							<img src={album.image} class="item-thumb music" alt={`${album.title} album art`} />
							<div class="item-content">
								<div class="item-header">
									<a href={album.url} class="item-title">{album.title}</a>
								</div>
								<p class="item-note">{album.artist}</p>
							</div>
						</div>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
