---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<nav class="footer-nav">
			<a href="/">Home</a>
			<a href="/blog/">Blog</a>
			<a href="/shorts/">Shorts</a>
			<a href="/now/">Now</a>
		</nav>
		<div class="footer-cc">
			<img src="https://mirrors.creativecommons.org/presskit/icons/cc.svg" alt="" class="cc-icon">
			<img src="https://mirrors.creativecommons.org/presskit/icons/by.svg" alt="" class="cc-icon">
			<span>
				<a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>
				&mdash; Michael Kumm &copy; {today.getFullYear()}
			</span>
		</div>
	</div>
</footer>

<style>
footer {
	margin-top: auto;
	border-top: 1px solid rgb(var(--gray-light));
	background: var(--bg-secondary);
}
.footer-inner {
	max-width: 1100px;
	margin: 0 auto;
	padding: 1.5rem 1.5rem;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 1rem;
}
.footer-nav {
	display: flex;
	gap: 1.5rem;
}
.footer-nav a {
	font-size: 0.875rem;
	color: rgb(var(--gray));
	text-decoration: none;
}
.footer-nav a:hover {
	color: var(--accent);
}
.footer-cc {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	color: rgb(var(--gray));
	font-size: 0.825rem;
}
.cc-icon {
	width: 1.1rem;
	height: 1.1rem;
	display: inline-block;
	margin: 0;
	border-radius: 0;
}
.footer-cc a {
	color: rgb(var(--gray));
	text-decoration: underline;
	text-decoration-color: rgba(var(--gray), 0.4);
}
.footer-cc a:hover {
	color: var(--accent);
}
</style>
