</header>

<style>
header {
	position: sticky;
	top: 0;
	z-index: 100;
	background: var(--header-bg);
	backdrop-filter: blur(12px);
	-webkit-backdrop-filter: blur(12px);
	border-bottom: 1px solid rgba(var(--gray-light), 0.6);
}

nav {
	display: flex;
	align-items: center;
	gap: 1rem;
	max-width: 1100px;
	margin: 0 auto;
	padding: 0 1.5rem;
	height: 64px;
}

/* ── Brand ── */
.site-brand {
	display: flex;
	align-items: center;
	gap: 0.6rem;
	text-decoration: none;
	flex-shrink: 0;
}


.site-name {
	font-size: 1rem;
	font-weight: 700;
	color: rgb(var(--black));
	letter-spacing: -0.02em;
	transition: color 0.2s ease;
}

.site-brand:hover .site-name {
	color: var(--accent);
}

/* ── Nav links ── */
.nav-links {
	display: flex;
	align-items: center;
	gap: 0.125rem;
	margin-left: auto;
}

/* Override global a styles for nav */
.nav-links :global(a) {
	display: inline-block;
	padding: 0.4em 0.8em;
	font-size: 0.9rem;
	font-weight: 500;
	color: rgb(var(--gray));
	text-decoration: none;
	border-radius: 6px;
	transition: color 0.15s ease, background 0.15s ease;
	border-bottom: none;
}

.nav-links :global(a:hover) {
	color: rgb(var(--black));
	background: rgba(var(--gray), 0.08);
	text-decoration: none;
}

.nav-links :global(a.active) {
	color: var(--accent);
	background: rgba(var(--accent-rgb), 0.1);
	font-weight: 600;
	border-bottom: none;
}

/* ── Right cluster ── */
.right-cluster {
	display: flex;
	align-items: center;
	gap: 0.25rem;
	margin-left: 0.75rem;
}

/* ── Social icons ── */
.social-links {
	display: flex;
	align-items: center;
	gap: 0.125rem;
}

.social-links a {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 34px;
	height: 34px;
	border-radius: 6px;
	color: rgb(var(--gray));
	text-decoration: none;
	transition: color 0.15s ease, background 0.15s ease;
}

.social-links a:hover {
	color: rgb(var(--black));
	background: rgba(var(--gray), 0.08);
}

.social-links svg {
	width: 17px;
	height: 17px;
}

/* ── Mobile toggle ── */
.mobile-toggle {
	display: none;
	align-items: center;
	justify-content: center;
	width: 36px;
	height: 36px;
	background: none;
	border: none;
	border-radius: 6px;
	cursor: pointer;
	color: rgb(var(--gray-dark));
	transition: background 0.15s ease;
}

.mobile-toggle:hover {
	background: rgba(var(--gray), 0.08);
}

/* ── Mobile social (inside dropdown) ── */
.mobile-social {
	display: none;
}

/* ── Mobile ── */
@media (max-width: 680px) {
	nav {
		height: 56px;
		padding: 0 1rem;
	}

	.right-cluster {
		margin-left: auto;
	}

	.nav-links {
		position: absolute;
		top: 56px;
		left: 0;
		right: 0;
		flex-direction: column;
		align-items: stretch;
		gap: 0;
		background: var(--header-bg-solid);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(var(--gray), 0.12);
		padding: 0.5rem;
		z-index: 99;
		max-height: 0;
		overflow: hidden;
		visibility: hidden;
		opacity: 0;
		transition: max-height 0.25s ease, opacity 0.2s ease, visibility 0.25s;
	}

	.nav-links.open {
		max-height: 400px;
		opacity: 1;
		visibility: visible;
	}

	.nav-links :global(a) {
		padding: 0.65em 0.75em;
		font-size: 0.95rem;
		border-radius: 6px;
	}

	.mobile-social {
		display: flex;
		gap: 0.25rem;
		padding: 0.5rem 0.25rem 0.25rem;
		margin-top: 0.25rem;
		border-top: 1px solid rgba(var(--gray), 0.12);
	}

	.mobile-social a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border-radius: 6px;
		color: rgb(var(--gray));
		text-decoration: none;
		transition: color 0.15s ease, background 0.15s ease;
	}

	.mobile-social a:hover {
		color: rgb(var(--black));
		background: rgba(var(--gray), 0.08);
	}

	.mobile-social svg {
		width: 18px;
		height: 18px;
	}

	.social-links {
		display: none;
	}

	.mobile-toggle {
		display: flex;
	}
}
</style>
